OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Optional Python FastAPI + LangGraph backend
LANGGRAPH_BACKEND_URL=http://127.0.0.1:8000

# Preferred LLM gateway
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
PUBLIC_APP_URL=http://localhost:5173

# Optional production guard. When set, workspace data routes require this token in
# x-ai-task-agent-access-token or Authorization: Bearer <token>.
WORKSPACE_ACCESS_TOKEN=

# Optional team workspaces for public deployments. Guest workspaces stay demo-open,
# while listed workspaces require their own token and can unlock real issue export.
# TEAM_WORKSPACES={"targix":{"label":"TargiX Product","token":"wat_team_secret"}}
TEAM_WORKSPACES=
# Alternative compact format: workspace:token:Label,workspace2:token2:Label
WORKSPACE_TEAM_TOKENS=

# Optional OpenAI-compatible proxy fallback. Works with either http://host:3001 or http://host:3001/v1.
FREELLMAPI_BASE_URL=
FREELLMAPI_API_KEY=
FREELLMAPI_MODEL=auto

# Supabase server-side storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare D1 server-side storage alternative
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_NAME=ai-task-agent
CLOUDFLARE_D1_PRIMARY_LOCATION_HINT=apac

# GitHub issue export
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# Linear issue export
LINEAR_API_KEY=
LINEAR_TEAM_ID=
